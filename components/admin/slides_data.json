[
  "<div class=\"slide active slide-centered\" id=\"welcomeSlide\" data-manual=\"true\">\r\n        <h1 class=\"big-title anim\" data-delay=\"300\">KÝ ỨC THĂNG LONG</h1>\r\n        <p class=\"subtitle anim\" data-delay=\"800\">Sẵn sàng cùng A5K58 ôn lại thanh xuân?</p>\r\n        <button class=\"start-btn anim\" data-delay=\"1500\" onclick=\"nextSlide()\">BẮT ĐẦU CHUYẾN TÀU</button>\r\n    </div>",
  "<div class=\"slide slide-centered\">\r\n        <p class=\"typewriter\" data-delay=\"800\">Mùa thu năm 2023... Chúng ta bước qua cánh cổng THPT Thăng Long với những bỡ ngỡ của tuổi 15.</p>\r\n        <p class=\"slide-desc anim\" data-delay=\"2500\">Mọi thứ bắt đầu bằng những ánh mắt rụt rè, những câu chào ngập ngừng...</p>\r\n    </div>",
  "<div class=\"slide slide-centered\">\r\n        <p class=\"chapter-label anim\" data-delay=\"300\">Hành trình thanh xuân</p>\r\n        <h1 class=\"big-title anim\" data-delay=\"800\">A5K58</h1>\r\n        <p class=\"subtitle anim\" data-delay=\"1400\">NIÊN KHÓA 2023 — 2026</p>\r\n        <p class=\"slide-quote anim\" data-delay=\"2000\">\"Chuyến tàu mang tên thanh xuân, chỉ có vé một chiều.\"</p>\r\n    </div>",
  "<div class=\"slide\">\r\n        <p class=\"chapter-label anim\" data-delay=\"100\">Khởi nguyên</p>\r\n        <h2 class=\"anim\" data-delay=\"300\">Những ngày đầu tiên</h2>\r\n        <p class=\"slide-desc anim\" data-delay=\"500\">Những mảnh ghép đầu tiên của một tập thể gắn kết. Ngày ấy, ai cũng\r\n            trông thật hiền lành...</p>\r\n\r\n        <div class=\"scattered-gallery\">\r\n            <div class=\"img-placeholder anim\" data-delay=\"700\">\r\n                <img src=\"a.png\" alt=\"Ảnh tập thể lớp\">\r\n            </div>\r\n            <div class=\"img-placeholder anim\" data-delay=\"900\">\r\n                <span class=\"ph-icon\">⚽</span>\r\n                <span>Ảnh FC đầu tiên</span>\r\n            </div>\r\n            <div class=\"img-placeholder anim\" data-delay=\"1100\">\r\n                <span class=\"ph-icon\">👋</span>\r\n                <span>Làm quen bạn mới</span>\r\n            </div>\r\n            <div class=\"img-placeholder anim\" data-delay=\"1300\">\r\n                <span class=\"ph-icon\">🏫</span>\r\n                <span>Góc sân trường</span>\r\n            </div>\r\n            <div class=\"img-placeholder anim\" data-delay=\"1500\">\r\n                <span class=\"ph-icon\">🎒</span>\r\n                <span>Bàn ghế mới</span>\r\n            </div>\r\n        </div>\r\n\r\n        <p class=\"slide-quote anim\" data-delay=\"1800\">\"Bắt đầu từ hai chữ 'bạn học', sau này gọi nhau là 'thanh xuân'.\"\r\n        </p>\r\n    </div>",
  "<div class=\"slide slide-centered\">\r\n        <div class=\"img-placeholder anim\" data-delay=\"200\" style=\"max-width:680px; border:none;\">\r\n            <span class=\"ph-icon\">📸</span>\r\n            <span>Ảnh bìa Lớp 10</span>\r\n        </div>\r\n        <p class=\"chapter-label anim\" data-delay=\"300\">Chương I</p>\r\n        <h1 class=\"anim\" data-delay=\"700\">Lớp 10: \"Chào cậu, người lạ chung bàn\"</h1>\r\n        <p class=\"typewriter\" data-delay=\"1600\">Lớp 10 — Khi thanh xuân bắt đầu gọi tên. Từ những cái tên mới toanh, những buổi sinh hoạt lớp còn ngại ngùng, chúng ta đã cùng nhau viết nên chương đầu tiên của một cuốn nhật ký rực rỡ...</p>\r\n        <p class=\"slide-desc anim\" data-delay=\"8000\">Chúng ta đã học cách nhường nhịn, chia sẻ và cùng nhau vượt qua những bài kiểm tra đầu tiên đầy bỡ ngỡ.</p>\r\n    </div>",
  "<div class=\"slide\">\r\n        <h2 class=\"anim\" data-delay=\"300\">Góc lầy lội — Phase 1</h2>\r\n        <p class=\"slide-desc anim\" data-delay=\"500\">Lúc này nhìn ai cũng có vẻ ngây thơ, nhưng thực ra mầm mống sơ hở là\r\n            bắt đầu từ đây...</p>\r\n\r\n        <div class=\"gallery-slideshow anim\" data-delay=\"800\">\r\n            <!-- Track 1: Left -->\r\n            <div class=\"gallery-track dir-left\">\r\n                <!-- 10 images -->\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 1</span></div>\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 2</span></div>\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 3</span></div>\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 4</span></div>\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 5</span></div>\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 6</span></div>\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 7</span></div>\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 8</span></div>\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 9</span></div>\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 10</span></div>\r\n                <!-- Duplicate for seamless loop -->\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 1</span></div>\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 2</span></div>\r\n                <div class=\"img-placeholder\"><span class=\"ph-icon\">🤪</span><span>Ảnh dìm 3</span></div>\r\n                <div class=\